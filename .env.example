# ============================================================
# Live Memory MCP Server — Configuration
# Copier ce fichier en .env et adapter les valeurs
# ============================================================

# --- Serveur MCP ---
MCP_SERVER_NAME=Live Memory
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8002
MCP_SERVER_DEBUG=false

# --- Auth ---
# ⚠️ Changer impérativement en production (≥ 32 chars aléatoires) !
ADMIN_BOOTSTRAP_KEY=change_me_in_production

# --- S3 Cloud Temple (Dell ECS) ---
# Configuration HYBRIDE obligatoire : SigV2 pour PUT/GET/DELETE,
# SigV4 pour HEAD/LIST. Path-style obligatoire.
S3_ENDPOINT_URL=https://your-endpoint.s3.fr1.cloud-temple.com
S3_ACCESS_KEY_ID=AKIA_YOUR_KEY
S3_SECRET_ACCESS_KEY=your_secret
S3_BUCKET_NAME=live-mem
S3_REGION_NAME=fr1

# --- LLMaaS Cloud Temple ---
# API OpenAI-compatible. L'URL INCLUT déjà /v1 — ne PAS l'ajouter dans le code.
LLMAAS_API_URL=https://api.ai.cloud-temple.com/v1
LLMAAS_API_KEY=your_llmaas_key
LLMAAS_MODEL=qwen3:235b
LLMAAS_CONTEXT_WINDOW=131072
LLMAAS_MAX_TOKENS=16384
LLMAAS_TEMPERATURE=0.3

# --- Rules par défaut ---
# Fichier Markdown chargé quand space_create est appelé sans paramètre rules.
# En Docker : /app/RULES/live-mem.standard.memory.bank.md
# En local : RULES/live-mem.standard.memory.bank.md (relatif au CWD)
DEFAULT_RULES_FILE=RULES/live-mem.standard.memory.bank.md

# --- Consolidation ---
CONSOLIDATION_TIMEOUT=600
CONSOLIDATION_MAX_NOTES=500
CONSOLIDATION_BATCH_SIZE=5

# --- Bank Compaction ---
# Compaction automatique des fichiers bank avant consolidation.
# COMPACT_THRESHOLD : ratio bank_size/max_tokens au-delà duquel on compacte (0.6 = 60%)
# BANK_FILE_MAX_SIZE : taille max universelle pour tout fichier bank (bytes, défaut 15 KB)
COMPACT_THRESHOLD=0.6
BANK_FILE_MAX_SIZE=15360

# --- WAF / Reverse Proxy ---
# Dev : SITE_ADDRESS=:8080 (HTTP, pas de TLS)
# Prod : SITE_ADDRESS=mon-service.example.com (TLS Let's Encrypt)
SITE_ADDRESS=:8080
WAF_PORT=8080

# ============================================================
# Configuration CLIENT CLI (ne pas mettre dans ce fichier)
# Utiliser des variables d'environnement shell à la place :
#   export MCP_URL=https://mon-service.example.com
#   export MCP_TOKEN=mon_token_secret
# ============================================================
