# ============================================================
# Live Memory MCP Server — Configuration
# Copier ce fichier en .env et adapter les valeurs
# ============================================================

# --- Serveur MCP ---
MCP_SERVER_NAME=Live Memory
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8002
MCP_SERVER_DEBUG=false

# --- Auth ---
# ⚠️ Changer impérativement en production (≥ 32 chars aléatoires) !
ADMIN_BOOTSTRAP_KEY=change_me_in_production

# --- S3 Cloud Temple (Dell ECS) ---
# Configuration HYBRIDE obligatoire : SigV2 pour PUT/GET/DELETE,
# SigV4 pour HEAD/LIST. Path-style obligatoire.
S3_ENDPOINT_URL=https://your-endpoint.s3.fr1.cloud-temple.com
S3_ACCESS_KEY_ID=AKIA_YOUR_KEY
S3_SECRET_ACCESS_KEY=your_secret
S3_BUCKET_NAME=live-mem
S3_REGION_NAME=fr1

# --- LLMaaS Cloud Temple ---
# Le consolidateur utilise un LLM pour transformer les notes live en fichiers bank.
# L'API est compatible OpenAI (chat.completions.create).
#
# LLMAAS_API_URL      : URL de l'API LLM. Doit inclure /v1.
# LLMAAS_API_KEY      : Clé d'API pour l'authentification.
# LLMAAS_MODEL        : Nom du modèle LLM à utiliser (tel qu'exposé par le provider).
#                        Exemples Cloud Temple : "qwen3.5:27b", "qwen3.5:27b"
# LLMAAS_CONTEXT_WINDOW : Taille TOTALE de la fenêtre de contexte du modèle (en tokens).
#                          C'est la capacité maximale du modèle en entrée + sortie combinés.
#                          Qwen 3.5 27B = 500000 tokens (500K). Ne pas dépasser la valeur
#                          supportée par le modèle — sinon les requêtes seront rejetées.
# LLMAAS_MAX_TOKENS   : Nombre maximum de tokens de SORTIE demandés à l'API par requête.
#                        C'est le budget pour la réponse du LLM (pas l'entrée).
#                        Le consolidateur ajuste ce budget dynamiquement :
#                        output = min(LLMAAS_MAX_TOKENS, CONTEXT_WINDOW - input_estimé)
#                        Valeur recommandée : 200000 avec un modèle 500K context.
# LLMAAS_TEMPERATURE  : Créativité du LLM (0.0 = déterministe, 1.0 = très créatif).
#                        0.3 est un bon compromis pour la consolidation (précis mais flexible).
#
LLMAAS_API_URL=https://api.ai.cloud-temple.com/v1
LLMAAS_API_KEY=your_llmaas_key
LLMAAS_MODEL=qwen3.5:27b
LLMAAS_CONTEXT_WINDOW=500000
LLMAAS_MAX_TOKENS=200000
LLMAAS_TEMPERATURE=0.3

# --- Proxy HTTP sortant (optionnel) ---
# Variable CUSTOM (pas HTTP_PROXY/HTTPS_PROXY) pour ne pas affecter toutes
# les libs Python qui lisent automatiquement les vars d'env OS.
# Injecté manuellement dans boto3 (S3) et httpx (LLM).
# Laisser vide ou ne pas définir pour un accès direct.
# Note : non supporté pour les connexions Graph Memory (streamablehttp_client).
#PROXY_URL=http://10.185.132.250:3128

# --- Rules par défaut ---
# Fichier Markdown chargé quand space_create est appelé sans paramètre rules.
# En Docker : /app/RULES/live-mem.standard.memory.bank.md
# En local : RULES/live-mem.standard.memory.bank.md (relatif au CWD)
DEFAULT_RULES_FILE=RULES/live-mem.standard.memory.bank.md

# --- Consolidation ---
# CONSOLIDATION_TIMEOUT    : Timeout par appel LLM en secondes. 600s = 10 min.
# CONSOLIDATION_MAX_NOTES  : Nombre max de notes traitées par consolidation.
#                             Au-delà, les notes excédentaires attendent la prochaine.
# CONSOLIDATION_BATCH_SIZE : Nombre de notes envoyées au LLM par lot.
#                             Des lots petits (2) = réponses JSON courtes = moins de drift.
#                             Des lots grands (5) = moins d'appels LLM = plus rapide.
CONSOLIDATION_TIMEOUT=600
CONSOLIDATION_MAX_NOTES=500
CONSOLIDATION_BATCH_SIZE=2

# --- Bank Compaction ---
# Compaction automatique des fichiers bank trop volumineux avant consolidation.
# Quand la bank consomme trop de la fenêtre de contexte LLM, les fichiers
# les plus gros sont résumés automatiquement via un appel LLM dédié.
#
# COMPACT_THRESHOLD    : Seuil de déclenchement. Si la bank dépasse ce ratio
#                         de LLMAAS_MAX_TOKENS, la compaction est déclenchée.
#                         0.6 = compacte si la bank occupe > 60% du budget.
# BANK_FILE_MAX_SIZE   : Taille max par fichier bank (en bytes). Les fichiers
#                         dépassant cette limite sont candidats à la compaction.
#                         15360 = 15 KB. Ajustable selon vos besoins.
COMPACT_THRESHOLD=0.6
BANK_FILE_MAX_SIZE=15360

# --- WAF / Reverse Proxy ---
# Dev : SITE_ADDRESS=:8080 (HTTP, pas de TLS)
# Prod : SITE_ADDRESS=mon-service.example.com (TLS Let's Encrypt)
SITE_ADDRESS=:8080
WAF_PORT=8080

# ============================================================
# Configuration CLIENT CLI (ne pas mettre dans ce fichier)
# Utiliser des variables d'environnement shell à la place :
#   export MCP_URL=https://mon-service.example.com
#   export MCP_TOKEN=mon_token_secret
# ============================================================
